# Existing Supabase project (SOURCE, read-only)
SOURCE_SUPABASE_URL=https://your-existing-project.supabase.co
SOURCE_SUPABASE_SERVICE_ROLE_KEY=your-existing-service-role-key

# New Supabase project (DESTINATION)
DEST_SUPABASE_URL=https://your-new-project.supabase.co
DEST_SUPABASE_SERVICE_ROLE_KEY=your-new-service-role-key

# Migration mode:
# - upsert: insert new rows, update changed rows
# - skip_existing: insert only rows not present by key
MIGRATION_MODE=upsert

# Batch size for paginated reads/writes
MIGRATION_BATCH_SIZE=500
